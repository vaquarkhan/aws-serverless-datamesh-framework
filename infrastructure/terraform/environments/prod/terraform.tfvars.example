# Copy to terraform.tfvars and customize bucket names (must be globally unique).

aws_region   = "us-east-2"
environment  = "prod"
name_prefix  = "sdm-prod"

checkpoint_bucket_name = "sdm-prod-checkpoints-YOUR_ACCOUNT_ID"
proof_bucket_name      = "sdm-prod-proofs-YOUR_ACCOUNT_ID"
lakehouse_bucket_name  = "sdm-prod-lakehouse-YOUR_ACCOUNT_ID"

glue_database_name = "raw_orders"
glue_table_name    = "orders_curated"
domain_id          = "orders-domain"

enable_durable_execution    = true
enable_step_functions       = true
enable_eventbridge_schedule = false
enable_monitoring_alarms    = true
trust_dashboard_domains     = ["orders", "payments", "inventory"]

# enable_lake_formation_governance = true
# consumer_principal_arn = "arn:aws:iam::123456789012:role/athena-consumer"

lambda_timeout_seconds              = 600   # 10 min segments in dev
durable_execution_timeout_seconds   = 3600  # 1 hour total
durable_retention_days              = 14
lambda_memory_mb                    = 2048
max_resume_attempts                 = 8
sfn_invoke_timeout_buffer_seconds   = 60
resume_wait_seconds                 = 30

# Production backfills (uncomment / override):
# lambda_timeout_seconds            = 900   # 15 min: AWS max per invocation
# durable_execution_timeout_seconds = 5400  # 90 min total durable budget
# lambda_memory_mb                  = 4096
# max_resume_attempts               = 10

# alarm_sns_topic_arns = ["arn:aws:sns:us-east-2:123456789012:platform-alerts"]
